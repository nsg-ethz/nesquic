FROM rust:1.94.1 AS builder

RUN apt-get update && apt-get install -y \
    libelf-dev \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /workspace
COPY Cargo.toml Cargo.lock ./
COPY iut/ iut/
COPY nesquic/ nesquic/
COPY utils/ utils/
COPY include/ include/

RUN cargo build --release --locked -p noq-iut --bin nesquic-noq

FROM nesquic/mahimahi

COPY --from=builder /workspace/target/release/nesquic-noq /usr/local/bin/nesquic-noq

ENV NESQUIC_BIN=/usr/local/bin/nesquic-noq
